    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5",
    "vite": "^8.0.10",
